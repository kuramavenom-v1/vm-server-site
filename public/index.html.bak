<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>VM - تسجيل الدخول</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="app">

  <h1>VM Roleplay</h1>

  <div class="card">

    <input id="name" placeholder="الاسم">
    <input id="age" placeholder="العمر">

    <select id="city">
      <option>Los Santos</option>
      <option>Paleto Bay</option>
      <option>Sandy Shores</option>
      <option>Grapeseed</option>
      <option>Harmony</option>
      <option>Chumash</option>
      <option>Banham Canyon</option>
      <option>Tongva Hills</option>
      <option>North Chumash</option>
    </select>

    <input id="psn" placeholder="PSN">
    <input type="file" id="image" accept="image/*">

    <button onclick="createIdentity()">إنشاء الهوية</button>

  </div>

</div>
<div id="idCard" class="id-card hidden">
  <div class="card-inner">
    
    <div class="card-front">
      <img id="cardImage" />
      <h2 id="cardName"></h2>
      <p id="cardId"></p>
      <p id="cardCity"></p>
      <p id="cardPSN"></p>
    </div>

    <div class="card-back">
      <h3>VM ID CARD</h3>
    </div>

  </div>
</div>
<script src="script.js"></script>
</body>
</html>