<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>VM - تسجيل الدخول</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="app">

  <h1>VM Roleplay</h1>

  <div class="card">

    <input id="name" placeholder="الاسم">
    <input id="age" placeholder="العمر">

    <select id="city">
      <option>Los Santos</option>
      <option>Paleto Bay</option>
      <option>Sandy Shores</option>
      <option>Grapeseed</option>
      <option>Harmony</option>
      <option>Chumash</option>
      <option>Banham Canyon</option>
      <option>Tongva Hills</option>
      <option>North Chumash</option>
    </select>

    <input id="psn" placeholder="PSN">
    <input type="file" id="image" accept="image/*">

    <button onclick="createIdentity()">إنشاء الهوية</button>

  </div>

</div>
<div id="idCard" class="id-card hidden">
  <div class="card-inner">

    <div class="card-front">

      <div class="id-header">
        <h3>REPUBLIC OF VM</h3>
        <span>IDENTITY CARD</span>
      </div>

      <div class="id-body">
        <img id="cardImage" class="avatar" />

        <div class="info">
          <h2 id="cardName"></h2>
          <p id="cardId"></p>
          <p id="cardCity"></p>
          <p id="cardPSN"></p>
        </div>
      </div>

      <div class="id-footer">
        <div class="signature">AUTHORIZED</div>
        <div class="qr"></div>
      </div>

    </div>

    <div class="card-back">
      <h3>VM GOVERNMENT DATABASE</h3>
    </div>

  </div>
</div>
</div>
<script src="script.js"></script>
</body>
</html>