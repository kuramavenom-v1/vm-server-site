.layout {
  display: flex;
  gap: 20px;
  justify-content: center;
  margin-top: 20px;
  flex-wrap: wrap;
}

/* 🪪 البطاقة */
.id-card {
  width: 420px;
  background: #1b1f2a;
  border-radius: 15px;
  padding: 15px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  border: 1px solid #2c3345;
}

.id-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  color: #38bdf8;
  font-weight: bold;
}

.id-body {
  display: flex;
  gap: 15px;
  align-items: center;
}

.id-img {
  width: 90px;
  height: 90px;
  border-radius: 10px;
  object-fit: cover;
  border: 2px solid #38bdf8;
}

.id-info h2 {
  margin: 0;
}

.id-info p {
  margin: 5px 0;
  font-size: 14px;
  color: #cbd5e1;
}

/* 📊 السيرفر */
.server-box {
  width: 250px;
  background: #111827;
  padding: 15px;
  border-radius: 12px;
  box-shadow: 0 10px 20px rgba(0,0,0,0.4);
}

.server-box h2 {
  color: #38bdf8;
}

.stat {
  margin: 10px 0;
  color: #e2e8f0;
}

/* 🔘 الأزرار */
.actions {
  margin-top: 20px;
  text-align: center;
}

.actions button {
  margin: 5px;
  padding: 10px 15px;
  border: none;
  border-radius: 8px;
  background: #38bdf8;
  cursor: pointer;
}

.actions button:hover {
  background: #0ea5e9;
}