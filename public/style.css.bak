html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow: hidden; /* نتركها لكن بنضبط الطبقات */
  background: #0f0f0f;
  font-family: Arial, sans-serif;
  color: #fff;
  position: relative;
}

/* مهم جداً */
.grid, .shapes {
  pointer-events: none;
}

/* الخلفية */
.grid {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.shapes {
  position: fixed;
  inset: 0;
  z-index: 1;
}

/* الكرت */
.center-container {
  position: relative;
  z-index: 10;
}

/* الكارد نفسه */
.card {
  position: relative;
  z-index: 11;
}

button {
  width: 100%;
  padding: 10px;
  border: none;
  border-radius: 8px;
  background: #ffffff;
  color: #000;
  cursor: pointer;
  box-sizing: border-box;
  font-weight: bold;
}

button:hover {
  background: #dddddd;
}

.hidden {
  display: none;
}

/* =================================================== */
/* تأثيرات الأشكال المتنوعة والشبكة الهندسية       */
/* =================================================== */

.grid {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(0, 85, 255, 0.04) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(0, 85, 255, 0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: moveGrid 8s linear infinite;
  z-index: 1;
}

@keyframes moveGrid {
  from { transform: translateY(0); }
  to { transform: translateY(40px); }
}

/* القاعدة الأساسية لكل الأشكال الخلفية */
.shapes span {
  position: absolute;
  z-index: 2;
  opacity: 0.35;
}

/* --- تصميم وتوزيع الأشكال المختلفة --- */

/* 1. مربع كلاسيكي يدور مع عقارب الساعة */
.shapes .square-1 {
  width: 18px;
  height: 18px;
  border: 2px solid #0055ff;
  top: 10%; left: 15%;
  animation: rotateClockwise 7s linear infinite;
}

/* 2. دائرة تتسع وتتقلص (تنبض) */
.shapes .circle-1 {
  width: 22px;
  height: 22px;
  border: 2px solid #0055ff;
  border-radius: 50%;
  top: 22%; left: 78%;
  animation: pulseShape 4s ease-in-out infinite alternate;
}

/* 3. شكل معين (Diamond) يدور بسرعة مختلفة */
.shapes .diamond-1 {
  width: 16px;
  height: 16px;
  border: 2px solid #0055ff;
  top: 75%; left: 18%;
  transform: rotate(45deg);
  animation: rotateCounterClockwise 9s linear infinite;
}

/* 4. كود مخصص لصناعة مثلث برمي متوهج خفيف */
.shapes .triangle-1 {
  width: 0;
  height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-bottom: 18px solid rgba(0, 85, 255, 0.7);
  top: 40%; left: 12%;
  animation: rotateClockwise 12s linear infinite;
}

/* 5. شكل سداسي/مربع مائل ذو حواف دائرية */
.shapes .hexagon-1 {
  width: 20px;
  height: 20px;
  border: 2px dashed #0055ff;
  border-radius: 4px;
  top: 82%; left: 75%;
  animation: rotateClockwise 5s linear infinite;
}

/* 6. مربع صغير مصمت (Solid) يختفي ويظهر */
.shapes .square-2 {
  width: 8px;
  height: 8px;
  background-color: #0055ff;
  top: 55%; left: 88%;
  animation: blinkShape 3s infinite;
}

/* 7. حلقة دائرية مزدوجة الخطوط */
.shapes .circle-2 {
  width: 30px;
  height: 30px;
  border: 1px double #0055ff;
  border-radius: 50%;
  top: 8%; left: 48%;
  animation: pulseShape 5s ease-in-out infinite alternate;
}

/* 8. معين آخر في زاوية مغايرة يدور عكس الاتجاه */
.shapes .diamond-2 {
  width: 14px;
  height: 14px;
  border: 2px solid #0055ff;
  top: 32%; left: 42%;
  animation: rotateCounterClockwise 6s linear infinite;
}

/* 9. مثلث مقلوب */
.shapes .triangle-2 {
  width: 0;
  height: 0;
  border-left: 8px solid transparent;
  border-right: 8px solid transparent;
  border-top: 15px solid rgba(0, 85, 255, 0.5);
  top: 68%; left: 48%;
  animation: rotateCounterClockwise 10s linear infinite;
}

/* 10 و 11. أشكال متقاطعة خفيفة جداً (Crosses) لزيادة التعقيد */
.shapes .cross-1 {
  width: 15px;
  height: 2px;
  background: #0055ff;
  top: 48%; left: 22%;
  transform: rotate(45deg);
}
.shapes .cross-1::after {
  content: '';
  position: absolute;
  width: 15px;
  height: 2px;
  background: #0055ff;
  transform: rotate(90deg);
}

.shapes .cross-2 {
  width: 15px;
  height: 2px;
  background: #0055ff;
  top: 88%; left: 42%;
  transform: rotate(120deg);
}
.shapes .cross-2::after {
  content: '';
  position: absolute;
  width: 15px;
  height: 2px;
  background: #0055ff;
  transform: rotate(90deg);
}

/* 12. حلقة متقطعة تدور ببطء شديد */
.shapes .ring-1 {
  width: 40px;
  height: 40px;
  border: 2px dashed rgba(0, 85, 255, 0.3);
  border-radius: 50%;
  top: 45%; left: 68%;
  animation: rotateClockwise 25s linear infinite;
}

/* =================================================== */
/* الأنماط الحركية (Animations)          */
/* =================================================== */

/* دوران مع عقارب الساعة مع تكبير خفيف */
@keyframes rotateClockwise {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

/* دوران عكس عقارب الساعة مع تكبير خفيف */
@keyframes rotateCounterClockwise {
  0% { transform: rotate(360deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(0deg) scale(1); }
}

/* نبض الحجم (الدوائر) */
@keyframes pulseShape {
  0% { transform: scale(0.9); opacity: 0.2; }
  100% { transform: scale(1.3); opacity: 0.5; }
}

/* الوميض والاختفاء التدريجي */
@keyframes blinkShape {
  0%, 100% { opacity: 0.1; }
  50% { opacity: 0.6; }
}
