body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0f0f0f;
  color: #ffffff;
}

h1 {
  text-align: center;
  margin-top: 20px;
}

.card {
  background: #1a1a1a;
  padding: 20px;
  margin: 20px auto;
  width: 300px;
  border-radius: 12px;
  box-shadow: 0 0 15px rgba(255,255,255,0.05);
}

input, select {
  width: 100%;
  padding: 10px;
  margin: 8px 0;
  border: 1px solid #333;
  border-radius: 8px;
  background: #111;
  color: #fff;
}

button {
  width: 100%;
  padding: 10px;
  margin-top: 10px;
  border: none;
  border-radius: 8px;
  background: #ffffff;
  color: #000;
  cursor: pointer;
}

button:hover {
  background: #dddddd;
}

.hidden {
  display: none;
}