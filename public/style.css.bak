/* إعدادات الشاشة الأساسية والتوسيط الموزون للجوال */
html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow: hidden; /* يمنع التمرير والحركة العشوائية تماماً على الجوال */
  background: #0f0f0f; /* لون الخلفية الأصلي المعين من قبلك */
  font-family: Arial, sans-serif;
  color: #ffffff;
}

/* حاوية التوسيط المطلق للكارد ليكون في السنتر تماماً */
.center-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 10; /* لضمان ظهور الكارد والأزرار فوق المؤثرات الخلفية */
}

h1 {
  text-align: center;
  margin: 0 0 15px 0; 
  font-size: 1.8rem; 
  padding: 0 10px;
}

.card {
  background: #1a1a1a; /* لون الكارد الأصلي الخاص بك */
  padding: 20px;
  width: 90%; 
  max-width: 300px; 
  border-radius: 12px;
  box-shadow: 0 0 15px rgba(255,255,255,0.05);
  box-sizing: border-box; 
  
  /* ترتيب داخلي مرن للأزرار لتطابق الأبعاد */
  display: flex;
  flex-direction: column;
  gap: 8px; 
}

input, select {
  width: 100%;
  padding: 10px;
  margin: 8px 0;
  border: 1px solid #333;
  border-radius: 8px;
  background: #111;
  color: #fff;
  box-sizing: border-box; 
}

button {
  width: 100%;
  padding: 10px;
  border: none;
  border-radius: 8px;
  background: #ffffff;
  color: #000;
  cursor: pointer;
  box-sizing: border-box;
  font-weight: bold;
}

button:hover {
  background: #dddddd;
}

.hidden {
  display: none;
}

/* =================================================== */
/*        تأثيرات الأشكال البرمجية والشبكة الهندسية       */
/* =================================================== */

/* خطوط شبكية متحركة عمودياً باللون الأزرق البرمجي الخفيف */
.grid {
  position: absolute;
  inset: 0;
  background-image: linear-gradient(rgba(0, 85, 255, 0.05) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(0, 85, 255, 0.05) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: moveGrid 6s linear infinite;
  z-index: 1;
}

@keyframes moveGrid {
  from { transform: translateY(0); }
  to { transform: translateY(40px); }
}

/* الأشكال الهندسية المعقدة الموزعة والمتحركة تلقائياً خلف الكارد */
.shapes span {
  position: absolute;
  width: 20px;
  height: 20px;
  border: 2px solid #0055ff;
  animation: rotateGeometric 6s linear infinite;
  opacity: 0.4;
  z-index: 2;
}

/* توزيع الأشكال الهندسية في زوايا مختلفة ومريحة للعين على الجوال */
.shapes span:nth-child(1) { top: 12%; left: 15%; }
.shapes span:nth-child(2) { top: 25%; left: 80%; border-radius: 50%; } /* شكل دائري */
.shapes span:nth-child(3) { top: 75%; left: 45%; transform: rotate(45deg); }
.shapes span:nth-child(4) { top: 85%; left: 15%; border-radius: 4px; } /* مربع ذو حواف */
.shapes span:nth-child(5) { top: 45%; left: 85%; }

/* حركة الدوران والنمو المعقدة المطابقة للبروتوكول الخاص بك */
@keyframes rotateGeometric {
  from { 
    transform: rotate(0deg) scale(1); 
  }
  to { 
    transform: rotate(360deg) scale(1.4); 
  }
}
