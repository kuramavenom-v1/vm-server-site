body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: radial-gradient(circle, #111, #000);
  color: white;
}

/* العنوان */
h1 {
  margin-top: 30px;
  font-size: 40px;
  letter-spacing: 2px;
}

/* الحاوية */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 90vh;
  flex-direction: column;
}

/* الكرت */
.card {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(10px);
  padding: 25px;
  border-radius: 15px;
  width: 350px;
  box-shadow: 0 0 20px rgba(0,255,100,0.2);
  transition: 0.3s;
}

.card:hover {
  transform: scale(1.02);
}

/* المدخلات */
input, select {
  width: 100%;
  padding: 12px;
  margin: 8px 0;
  border: none;
  border-radius: 8px;
  outline: none;
}

/* الزر */
button {
  width: 100%;
  padding: 12px;
  background: #00c853;
  border: none;
  border-radius: 8px;
  color: white;
  font-weight: bold;
  cursor: pointer;
}

button:hover {
  background: #00e676;
}

/* 📱 الجوال */
@media (max-width: 600px) {
  .card {
    width: 90%;
  }

  h1 {
    font-size: 28px;
  }
}