* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: Arial, sans-serif;
}

html, body {
  width: 100%;
  height: 100%;
  overflow: hidden !important;
  position: fixed;
}

/* تطبيق ثابت */
.app {
  width: 100vw;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
} 

/* عنوان */
h1 {
  font-size: 28px;
  margin-bottom: 20px;
  color: #00e676;
  text-align: center;
}

/* كرت تسجيل الدخول */
.card {
  width: 380px;
  background: #14141a;
  padding: 25px;
  border-radius: 18px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.6);
}

/* مدخلات */
input, select {
  width: 100%;
  padding: 14px;
  margin: 10px 0;
  border: 1px solid #2a2a35;
  border-radius: 10px;
  background: #0f0f15;
  color: white;
  outline: none;
}

input:focus, select:focus {
  border-color: #00e676;
}

/* زر */
button {
  width: 100%;
  padding: 14px;
  background: linear-gradient(90deg, #00c853, #00e676);
  border: none;
  border-radius: 10px;
  color: black;
  font-weight: bold;
  cursor: pointer;
  margin-top: 10px;
}

button:active {
  transform: scale(0.98);
}

/* 📱 الجوال */
@media (max-width: 600px) {
  .card {
    width: 90%;
  }

  h1 {
    font-size: 22px;
  }
}