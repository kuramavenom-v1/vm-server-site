/* =========================
   RESET
========================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

html, body {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #0f0f0f;
  color: #fff;
}

/* =========================
   LAYOUT (مهم لكل الصفحات)
========================= */

.center-container {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  z-index: 10;
}

/* =========================
   CARD
========================= */

.card {
  width: 90%;
  max-width: 320px;
  background: #1a1a1a;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  box-shadow: 0 0 12px rgba(255,255,255,0.05);

  display: flex;
  flex-direction: column;
  gap: 10px;
}

h1 {
  font-size: 1.6rem;
  margin-bottom: 10px;
}

/* =========================
   BUTTONS
========================= */

button {
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 8px;

  background: #fff;
  color: #000;
  font-weight: bold;

  cursor: pointer;
  transition: 0.2s;
}

button:hover {
  background: #ddd;
}

/* =========================
   INPUTS (لو عندك تسجيل)
========================= */

input, select {
  width: 100%;
  padding: 10px;
  border-radius: 6px;
  border: none;
  outline: none;

  background: #111;
  color: #fff;
  border: 1px solid #333;
}

/* =========================
   HIDDEN
========================= */

.hidden {
  display: none;
}

/* =========================
   BACKGROUND GRID
========================= */

.grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);

  background-size: 40px 40px;
  z-index: 1;
}

/* =========================
   SHAPES (خفيف بدون ضغط)
========================= */

.shapes span {
  position: absolute;
  opacity: 0.2;
  z-index: 2;
}

/* شكل بسيط بدون أنيميشن ثقيل */
.square-1, .circle-1, .diamond-1 {
  width: 12px;
  height: 12px;
  border: 2px solid #fff;
}

.circle-1 {
  border-radius: 50%;
}

.diamond-1 {
  transform: rotate(45deg);
}

input,
select {
  width: 100%;
  padding: 12px;
  margin-bottom: 10px;
  border-radius: 8px;
  border: 1px solid #333;
  background: #111;
  color: white;
  box-sizing: border-box;
  font-size: 14px;
}

/* =========================
   MOBILE SAFE
========================= */

@media (max-width: 480px) {
  .card {
    max-width: 95%;
    padding: 16px;
  }

  h1 {
    font-size: 1.4rem;
  }
}