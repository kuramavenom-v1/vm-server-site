/* =========================
   RESET + BASE
========================= */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

html, body{
  width:100%;
  height:100%;
  overflow:hidden;
  background:#0f0f0f;
  color:#fff;
}

/* =========================
   BACKGROUND (GRID)
========================= */

.grid{
  position:fixed;
  inset:0;
  z-index:1;

  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);

  background-size:40px 40px;
}

/* =========================
   CENTER WRAPPER (ثابت لكل الصفحات)
========================= */

.center-container{
  width:100%;
  height:100%;
  display:flex;
  justify-content:center;
  align-items:center;
  position:relative;
  z-index:10;
  padding:15px;
}

/* =========================
   CARD (موحد لكل الصفحات)
========================= */

.card{
  width:100%;
  max-width:340px;

  background:#1a1a1a;
  border:1px solid #2c2c2c;

  border-radius:14px;
  padding:20px;

  display:flex;
  flex-direction:column;
  gap:10px;

  box-shadow:0 0 20px rgba(255,255,255,0.03);
}

.card h1{
  text-align:center;
  font-size:1.6rem;
  margin-bottom:10px;
}

.card p{
  text-align:center;
  color:#bbb;
  font-size:14px;
}

/* =========================
   INPUTS / SELECT
========================= */

input,
select{
  width:100%;
  padding:12px;

  border-radius:8px;
  border:1px solid #333;

  background:#111;
  color:#fff;

  font-size:14px;
  outline:none;
}

input:focus,
select:focus{
  border-color:#666;
}

/* =========================
   BUTTONS
========================= */

button{
  width:100%;
  padding:12px;

  border:none;
  border-radius:8px;

  background:#fff;
  color:#000;

  font-weight:bold;
  font-size:14px;

  cursor:pointer;
  transition:0.2s;
}

button:hover{
  background:#e5e5e5;
}

/* زر ثانوي (رجوع) */
.back-btn{
  background:transparent;
  color:#fff;
  border:1px solid #444;
}

.back-btn:hover{
  background:#222;
}

/* =========================
   DASHBOARD LAYOUT
========================= */

.dashboard{
  width:100%;
  max-width:900px;
}

.top-info{
  display:flex;
  gap:15px;
  align-items:stretch;
}

/* =========================
   ID CARD (بطاقة الهوية)
========================= */

.id-card{
  flex:1;

  background:linear-gradient(145deg,#ffffff,#eaeaea);
  color:#000;

  border-radius:16px;
  padding:18px;

  border:1px solid #ddd;
  box-shadow:0 0 20px rgba(255,255,255,0.06);
}

.id-header{
  display:flex;
  justify-content:space-between;
  font-weight:bold;
  font-size:13px;
  margin-bottom:10px;
}

.id-body{
  display:flex;
  gap:12px;
  align-items:center;
}

.id-img{
  width:75px;
  height:75px;

  border-radius:12px;
  object-fit:cover;

  border:2px solid #000;
}

.id-info h2{
  font-size:16px;
  margin-bottom:6px;
}

.id-info p{
  font-size:13px;
  margin:4px 0;
}

/* =========================
   SERVER BOX
========================= */

.server-box{
  flex:1;

  background:#111;
  border:1px solid #2a2a2a;

  border-radius:16px;
  padding:18px;

  box-shadow:0 0 15px rgba(0,255,100,0.08);
}

.server-box h3{
  margin-bottom:10px;
}

.stat{
  margin:8px 0;
  font-size:14px;
  color:#ddd;
}

/* النقطة الخضراء */
.online-dot{
  width:9px;
  height:9px;
  border-radius:50%;
  background:#00ff66;
  display:inline-block;

  box-shadow:0 0 10px #00ff66;
}

/* =========================
   ACTIONS
========================= */

.actions{
  margin-top:15px;
  display:flex;
  flex-direction:column;
  gap:10px;
}

/* =========================
   HIDDEN
========================= */

.hidden{
  display:none;
}

/* =========================
   MOBILE FIX (ثبات الشكل)
========================= */

@media(max-width:768px){
  .top-info{
    flex-direction:column;
  }

  .card{
    max-width:340px;
  }
}