<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>إنشاء هوية</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<h1>إنشاء هوية جديدة</h1>

<div class="center-container">
  <div class="card">

    <h1>إنشاء هوية جديدة</h1>

    <input type="text" id="name" placeholder="الاسم الكامل">

    <input type="number" id="age" placeholder="العمر">

    <select id="city">
      <option value="">اختر المدينة</option>
      <option value="Los Santos">Los Santos</option>
      <option value="Paleto Bay">Paleto Bay</option>
      <option value="Sandy Shores">Sandy Shores</option>
    </select>

    <input type="text" id="psn" placeholder="PSN">

    <button onclick="createIdentity()">
      إنشاء الهوية
    </button>

    <button onclick="location.href='index.html'">
      رجوع
    </button>

  </div>
</div>

<script src="script.js"></script>
</body>
</html>