<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>روابط السيرفر</title>

<style>

/* =========================
   BASE
========================= */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  background:#05070d;
  color:#e6f1ff;
  padding:20px;
}

/* =========================
   CONTAINER
========================= */
.container{
  max-width:650px;
  margin:auto;
}

/* =========================
   HEADER
========================= */
header{
  text-align:center;
  padding:22px;
  margin-bottom:20px;

  background:linear-gradient(145deg,#0b1220,#070a12);
  border:1px solid rgba(0,140,255,0.25);
  border-radius:14px;

  box-shadow:0 0 18px rgba(0,140,255,0.15);
}

header h1{
  color:#4db5ff;
  font-size:1.5rem;
  text-shadow:0 0 10px rgba(0,140,255,0.6);
}

header p{
  color:#a9c7e6;
  font-size:0.9rem;
}

/* =========================
   BUTTONS
========================= */
.links{
  display:flex;
  flex-direction:column;
  gap:12px;
  margin-top:20px;
}

.btn{
  position:relative;
  width:100%;
  padding:14px;

  border:none;
  border-radius:12px;

  cursor:pointer;

  background:linear-gradient(145deg,#0a0f1a,#060912);
  border:1px solid rgba(0,140,255,0.25);

  color:#e6f1ff;
  font-size:14px;
  font-weight:bold;

  box-shadow:0 0 12px rgba(0,140,255,0.1);

  transition:0.2s;
}

.btn:hover{
  transform:scale(1.02);
  box-shadow:0 0 18px rgba(0,140,255,0.25);
}

.small{
  font-size:12px;
  color:#4db5ff;
  margin-top:4px;
  font-weight:normal;
}

/* =========================
   CLICK EFFECT
========================= */
.btn:active{
  transform:scale(0.98);
}

</style>

</head>

<body>

<div class="container">

<header>
  <h1>روابط السيرفر</h1>
  <p>جميع روابط التواصل الرسمية</p>
</header>

<div class="links">

  <!-- واتس قناة -->
  <button class="btn" onclick="openLink('https://whatsapp.com/channel/0029Vb8BhcxHwXbIcEB4NA1V')">
    قناة السيرفر - WA
    <div class="small">WhatsApp Channel</div>
  </button>

  <!-- تيك توك -->
  <button class="btn" onclick="openLink('https://www.tiktok.com/@vm_server')">
    قناة السيرفر - TikTok
    <div class="small">TikTok Official</div>
  </button>

  <!-- واتس اونر -->
  <button class="btn" onclick="openLink('https://wa.me/201214684186')">
    التواصل مع الأونر - WhatsApp
    <div class="small">Chat Direct</div>
  </button>

  <!-- تيلي اونر -->
  <button class="btn" onclick="openLink('https://t.me/V_K_U1')">
    التواصل مع الأونر - Telegram
    <div class="small">@V_K_U1</div>
  </button>

</div>

</div>

<script>
function openLink(url){
  window.open(url, "_blank");
}
</script>

</body>
</html>